---
import Base from '../layouts/Base.astro';
export const prerender = true;
---

<Base 
  title="ArbRemote — Earn USD. Live Anywhere." 
  description="The premier arbitrage network for expat founders and remote engineers. Capitalize on geography and maximize your earnings."
>
  <nav class="fixed-nav">
    <div class="container nav-content">
      <div class="logo">ArbRemote</div>
      <button id="themeToggle" class="theme-btn" aria-label="Toggle dark mode">
        <svg class="sun" viewBox="0 0 24 24" width="24" height="24"><path fill="currentColor" d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58a.996.996 0 00-1.41 0 .996.996 0 000 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37a.996.996 0 00-1.41 0 .996.996 0 000 1.41l1.06 1.06c.39.39 1.03.39 1.41 0a.996.996 0 000-1.41l-1.06-1.06zm1.06-12.37a.996.996 0 000-1.41.996.996 0 00-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06zm-12.37 12.37a.996.996 0 000-1.41.996.996 0 00-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41.39.39 1.03.39 1.41 0l1.06-1.06z"/></svg>
        <svg class="moon" viewBox="0 0 24 24" width="24" height="24"><path fill="currentColor" d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-.46-.04-.92-.1-1.36-.98 1.37-2.58 2.26-4.4 2.26-3.03 0-5.5-2.47-5.5-5.5 0-1.82.89-3.42 2.26-4.4-.44-.06-.9-.1-1.36-.1z"/></svg>
      </button>
    </div>
  </nav>

  <main>
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <div class="eyebrow-pill animated">Now Active for 2026 Q2</div>
          <h1>Earn USD.<br/>Live Anywhere.</h1>
          <p class="subtitle italic">Arbitrage your life. Maximize your focus.</p>
          
          <div class="hero-cta">
            <iframe src="https://subscribe-forms.beehiiv.com/3f5ff9b2-593c-48d9-bcc2-fa6bdf772e7c?slim=true" data-test-id="beehiiv-embed" frameborder="0" scrolling="no" style="margin: 0; border-radius: 0px !important; background-color: transparent; width: 100%; height: 52px;"></iframe>
          </div>
        </div>
      </div>
    </section>

    <section class="math-grid container">
      <div class="math-card">
        <div class="label">Average Rate</div>
        <div class="value">$45/hr</div>
      </div>
      <div class="math-card accent">
        <div class="label">Local Rate (PH)</div>
        <div class="value">60 PHP</div>
      </div>
      <div class="math-card">
        <div class="label">Profit Savings</div>
        <div class="value">83%</div>
      </div>
      <div class="math-card">
        <div class="label">Curated Roles</div>
        <div class="value">200+</div>
      </div>
      <div class="math-card accent">
        <div class="label">Weekly Burn</div>
        <div class="value">$700</div>
      </div>
    </section>

    <section class="arbitrage-comparison container">
      <h2 class="section-title">The Arbitrage Equation</h2>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Factor</th>
              <th>US Standard (SF/NYC)</th>
              <th>ArbRemote (Global)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Internal Salary</td>
              <td>$140,000</td>
              <td>$140,000</td>
            </tr>
            <tr>
              <td>Monthly Rent</td>
              <td>$4,200</td>
              <td>$850 (Villa)</td>
            </tr>
            <tr>
              <td>Effective Tax</td>
              <td>35%</td>
              <td>0% - 15% (Digital Nomad)</td>
            </tr>
            <tr>
              <td>Net Monthly Savings</td>
              <td>$1,200</td>
              <td>$7,100</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="pillars container">
      <div class="pillar-card">
        <h3>Weekly Job Drops</h3>
        <p>Vetted high-paying USD roles from US companies open to global talent.</p>
      </div>
      <div class="pillar-card">
        <h3>Arbitrage Playbooks</h3>
        <p>Step-by-step guides for residency, banking, and life optimization.</p>
      </div>
      <div class="pillar-card">
        <h3>Grant Intelligence</h3>
        <p>Access to non-dilutive funding and global startup grants.</p>
      </div>
      <div class="pillar-card">
        <h3>Expat Founder Insights</h3>
        <p>Network with engineers and founders living the arbitrage lifestyle.</p>
      </div>
    </section>

    <section class="quote-section">
      <div class="container">
        <blockquote class="full-width-quote">
          "Geography is not a lifestyle choice. It's a capitalization strategy."
        </blockquote>
      </div>
    </section>

    <section class="footer-cta container">
      <div class="cta-box">
        <h2>Join the Arbitrage List</h2>
        <p>Get the first look at the 2026 Q3 Arbitrage Report.</p>
        <iframe src="https://subscribe-forms.beehiiv.com/3f5ff9b2-593c-48d9-bcc2-fa6bdf772e7c?slim=true" data-test-id="beehiiv-embed-footer" frameborder="0" scrolling="no" style="margin: 0; border-radius: 0px !important; background-color: transparent; width: 100%; height: 52px;"></iframe>
      </div>
    </section>
  </main>

  <footer class="main-footer">
    <div class="container footer-content">
      <div class="copyright">&copy; 2026 ArbRemote / GalaxyBuilt</div>
      <div class="footer-links">
        <a href="#">Galaxy Arbitrage List</a>
        <a href="https://x.com/arbremote" target="_blank">@arbremote</a>
      </div>
    </div>
  </footer>
</Base>

<style>
  .fixed-nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background-color: var(--current-bg);
    border-bottom: 1px solid rgba(200, 146, 42, 0.2);
    padding: 1rem 0;
    backdrop-filter: blur(10px);
  }

  .nav-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.05em;
    color: var(--accent);
  }

  .theme-btn {
    background: none;
    border: none;
    color: var(--current-text);
    cursor: pointer;
    padding: 0.5rem;
    display: flex;
    align-items: center;
    border-radius: 50%;
    transition: background-color 0.2s;
  }

  .theme-btn:hover {
    background-color: rgba(200, 146, 42, 0.1);
  }

  [data-theme='light'] .moon { display: block; }
  [data-theme='light'] .sun { display: none; }
  [data-theme='dark'] .moon { display: none; }
  [data-theme='dark'] .sun { display: block; }

  /* Hero Section */
  .hero {
    padding: 10rem 0 6rem;
    text-align: center;
  }

  .eyebrow-pill {
    display: inline-block;
    padding: 0.25rem 1rem;
    border-radius: 999px;
    background-color: rgba(200, 146, 42, 0.1);
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    border: 1px solid var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .animated {
    animation: pulse 2s infinite ease-in-out;
  }

  @keyframes pulse {
    0% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.05); opacity: 1; }
    100% { transform: scale(1); opacity: 0.8; }
  }

  h1 {
    font-size: 5rem;
    line-height: 1;
    margin-bottom: 1rem;
    color: var(--current-text);
  }

  .subtitle {
    font-size: 1.5rem;
    opacity: 0.8;
    margin-bottom: 3rem;
  }

  .hero-cta {
    max-width: 450px;
    margin: 0 auto;
  }

  /* Math Grid */
  .math-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 8rem;
  }

  .math-card {
    border: 1px solid rgba(200, 146, 42, 0.2);
    padding: 2rem;
    text-align: center;
    background-color: rgba(200, 146, 42, 0.03);
  }

  .math-card.accent {
    background-color: var(--accent);
    color: white;
  }

  .math-card .value {
    font-size: 2.5rem;
    font-weight: 800;
    font-family: 'DM Mono', monospace;
  }

  .math-card .label {
    font-size: 0.9rem;
    opacity: 0.7;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }

  /* Comparison Table */
  .arbitrage-comparison {
    margin-bottom: 8rem;
  }

  .section-title {
    font-size: 3rem;
    text-align: center;
    margin-bottom: 3rem;
  }

  .table-wrapper {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'DM Mono', monospace;
  }

  th, td {
    padding: 1.5rem;
    text-align: left;
    border-bottom: 1px solid rgba(200, 146, 42, 0.2);
  }

  th {
    color: var(--accent);
    text-transform: uppercase;
    font-size: 0.8rem;
  }

  td:last-child {
    font-weight: 700;
    color: var(--accent);
  }

  /* Pillars */
  .pillars {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-bottom: 8rem;
  }

  .pillar-card {
    padding: 2.5rem;
    border: 1px solid rgba(200, 146, 42, 0.1);
    transition: transform 0.3s ease;
  }

  .pillar-card:hover {
    transform: translateY(-5px);
    border-color: var(--accent);
  }

  .pillar-card h3 {
    margin-bottom: 1rem;
    color: var(--accent);
  }

  /* Quote */
  .quote-section {
    padding: 8rem 0;
    background-color: var(--accent);
    color: white;
    text-align: center;
    margin-bottom: 8rem;
  }

  .full-width-quote {
    font-size: 3.5rem;
    font-style: italic;
    line-height: 1.1;
    max-width: 900px;
    margin: 0 auto;
  }

  /* Footer CTA */
  .footer-cta {
    margin-bottom: 8rem;
    text-align: center;
  }

  .cta-box {
    padding: 5rem 2rem;
    border: 2px solid var(--accent);
    max-width: 800px;
    margin: 0 auto;
  }

  /* Footer */
  .main-footer {
    padding: 4rem 0;
    border-top: 1px solid rgba(200, 146, 42, 0.1);
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-links a {
    color: var(--current-text);
    text-decoration: none;
    margin-left: 2rem;
    opacity: 0.7;
  }

  .footer-links a:hover {
    opacity: 1;
    color: var(--accent);
  }

  .italic {
    font-style: italic;
  }

  @media (max-width: 768px) {
    h1 { font-size: 3rem; }
    .full-width-quote { font-size: 2rem; }
    .footer-content { flex-direction: column; gap: 1rem; text-align: center; }
    .footer-links a { margin: 0 1rem; }
  }
</style>
